      <description>&lt;p&gt;Initial notes for the six-month follow-up.&lt;/p&gt;
&lt;p&gt;Key metrics and charts will be added next.&lt;/p&gt;
&lt;p&gt;Outline pending final data spec.&lt;/p&gt;
&lt;script src=&#34;http://localhost:1313/vendor/chartjs/chart.umd.min.js&#34; defer&gt;&lt;/script&gt;
  &lt;script src=&#34;http://localhost:1313/vendor/papaparse/papaparse.min.js&#34; defer&gt;&lt;/script&gt;&lt;div class=&#34;chart-block&#34; id=&#34;chart-container-1&#34;&gt;&lt;div class=&#34;chart-title&#34;&gt;Outstanding Loans Market Share&lt;/div&gt;&lt;div class=&#34;chart-canvas&#34; style=&#34;height: 420px;&#34;&gt;
    &lt;canvas id=&#34;chart-canvas-1&#34; role=&#34;img&#34; aria-label=&#34;Outstanding Loans Market Share&#34;&gt;&lt;/canvas&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;script&gt;
(() =&gt; {
  const chartJsUrl = &#34;/vendor/chartjs/chart.umd.min.js&#34;;
  const papaUrl = &#34;/vendor/papaparse/papaparse.min.js&#34;;

  const loadScript = (src) =&gt; new Promise((resolve, reject) =&gt; {
    const script = document.createElement(&#34;script&#34;);
    script.src = src;
    script.async = true;
    script.onload = () =&gt; resolve();
    script.onerror = () =&gt; reject(new Error(`Failed to load ${src}`));
    document.head.appendChild(script);
  });

  const ensureDeps = () =&gt; {
    if (window.__chartDepsPromise) {
      return window.__chartDepsPromise;
    }
    window.__chartDepsPromise = new Promise(async (resolve, reject) =&gt; {
      if (typeof Chart !== &#34;undefined&#34; &amp;&amp; typeof Papa !== &#34;undefined&#34;) {
        resolve();
        return;
      }
      const tasks = [];
      if (typeof Chart === &#34;undefined&#34;) {
        tasks.push(loadScript(chartJsUrl));
      }
      if (typeof Papa === &#34;undefined&#34;) {
        tasks.push(loadScript(papaUrl));
      }
      const results = await Promise.allSettled(tasks);
      const failed = results.find((result) =&gt; result.status === &#34;rejected&#34;);
      if (failed) {
        reject(failed.reason);
        return;
      }
      if (typeof Chart === &#34;undefined&#34; || typeof Papa === &#34;undefined&#34;) {
        reject(new Error(&#34;Chart.js or PapaParse not loaded&#34;));
        return;
      }
      resolve();
    });
    return window.__chartDepsPromise;
  };

  const onReady = () =&gt; {
    ensureDeps().then(() =&gt; {

    const config = {&#34;canvasId&#34;:&#34;chart-canvas-1&#34;,&#34;colors&#34;:&#34;&#34;,&#34;containerId&#34;:&#34;chart-container-1&#34;,&#34;src&#34;:&#34;/data/aave-six-months-later/outstanding-loans-marketshare.csv&#34;,&#34;stacked&#34;:true,&#34;title&#34;:&#34;Outstanding Loans Market Share&#34;,&#34;type&#34;:&#34;area&#34;,&#34;x&#34;:&#34;&#34;,&#34;y&#34;:&#34;&#34;,&#34;ymax&#34;:&#34;100&#34;,&#34;ymin&#34;:&#34;0&#34;};

    const container = document.getElementById(config.containerId);
    const canvas = document.getElementById(config.canvasId);
    if (!container || !canvas) {
      return;
    }

    const parseList = (value) =&gt;
      value.split(&#34;,&#34;).map((item) =&gt; item.trim()).filter(Boolean);

    const basePalette = [
      &#34;#2f6b5f&#34;,
      &#34;#b36b00&#34;,
      &#34;#2f4b7c&#34;,
      &#34;#a05195&#34;,
      &#34;#d45087&#34;,
      &#34;#6b7c93&#34;,
      &#34;#006d77&#34;,
      &#34;#bc5090&#34;
    ];

    const buildColors = (count, custom) =&gt; {
      const output = [];
      const source = custom &amp;&amp; custom.length ? custom : basePalette;
      for (let i = 0; i &lt; count; i += 1) {
        if (i &lt; source.length) {
          output.push(source[i]);
        } else {
          const hue = Math.round((360 / count) * i);
          output.push(`hsl(${hue}, 65%, 55%)`);
        }
      }
      return output;
    };

    const hexToRgba = (hex, alpha) =&gt; {
      const raw = hex.replace(&#34;#&#34;, &#34;&#34;);
      if (raw.length !== 6) {
        return hex;
      }
      const r = parseInt(raw.slice(0, 2), 16);
      const g = parseInt(raw.slice(2, 4), 16);
      const b = parseInt(raw.slice(4, 6), 16);
      return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    };

    const withAlpha = (color, alpha) =&gt; {
      if (color.startsWith(&#34;#&#34;)) {
        return hexToRgba(color, alpha);
      }
      if (color.startsWith(&#34;rgb(&#34;)) {
        const values = color.replace(&#34;rgb(&#34;, &#34;&#34;).replace(&#34;)&#34;, &#34;&#34;);
        return `rgba(${values}, ${alpha})`;
      }
      return color;
    };

    const customColors = config.colors ? parseList(config.colors) : [];

    fetch(config.src)
      .then((response) =&gt; {
        if (!response.ok) {
          throw new Error(`Failed to fetch ${config.src}`);
        }
        return response.text();
      })
      .then((csvText) =&gt; {
        const parsed = Papa.parse(csvText, {
          header: true,
          dynamicTyping: true,
          skipEmptyLines: true
        });

        const rows = parsed.data || [];
        const fields = (parsed.meta &amp;&amp; parsed.meta.fields) || [];
        if (!rows.length || !fields.length) {
          console.warn(&#34;No chart data for&#34;, config.src);
          return;
        }

        const xColumn = config.x || fields[0];
        let yColumns = [];
        if (config.y) {
          yColumns = parseList(config.y);
        } else {
          yColumns = fields.filter((field) =&gt; field !== xColumn);
        }

        if (!yColumns.length) {
          console.warn(&#34;No y-axis columns for&#34;, config.src);
          return;
        }

        const labels = rows.map((row) =&gt; row[xColumn]);
        let chartType = config.type || &#34;line&#34;;
        const isArea = chartType === &#34;area&#34;;
        if (isArea) {
          chartType = &#34;line&#34;;
        }
        const isPie = chartType === &#34;pie&#34; || chartType === &#34;doughnut&#34;;

        let datasets = [];
        if (isPie) {
          const yKey = yColumns[0];
          const pieColors = buildColors(labels.length, customColors);
          datasets = [
            {
              label: yKey,
              data: rows.map((row) =&gt; row[yKey]),
              backgroundColor: pieColors,
              borderColor: &#34;rgba(255, 255, 255, 0.6)&#34;,
              borderWidth: 1
            }
          ];
        } else {
          const seriesColors = buildColors(yColumns.length, customColors);
          datasets = yColumns.map((column, index) =&gt; {
            const baseColor = seriesColors[index % seriesColors.length];
            return {
              label: column,
              data: rows.map((row) =&gt; row[column]),
              borderColor: baseColor,
              backgroundColor: withAlpha(baseColor, isArea ? 0.2 : 0.1),
              fill: isArea,
              tension: 0.3,
              borderWidth: 2,
              pointRadius: 2,
              pointHoverRadius: 4
            };
          });
        }

        const style = getComputedStyle(container);
        const gridColor = style.getPropertyValue(&#34;--chart-grid&#34;).trim() || &#34;rgba(0, 0, 0, 0.08)&#34;;
        const textColor = style.getPropertyValue(&#34;--chart-text&#34;).trim() || &#34;rgba(0, 0, 0, 0.75)&#34;;
        const showLegend = isPie || yColumns.length &gt; 1;

        const options = {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: showLegend,
              labels: {
                color: textColor,
                boxWidth: 14
              }
            },
            tooltip: {
              mode: &#34;index&#34;,
              intersect: false
            }
          }
        };

        if (!isPie) {
          const yMin = config.ymin !== &#34;&#34; ? Number(config.ymin) : null;
          const yMax = config.ymax !== &#34;&#34; ? Number(config.ymax) : null;
          options.scales = {
            x: {
              stacked: !!config.stacked,
              grid: {
                color: gridColor
              },
              ticks: {
                color: textColor
              }
            },
            y: {
              stacked: !!config.stacked,
              min: Number.isFinite(yMin) ? yMin : undefined,
              max: Number.isFinite(yMax) ? yMax : undefined,
              grid: {
                color: gridColor
              },
              ticks: {
                color: textColor
              }
            }
          };
        }

        new Chart(canvas, {
          type: chartType,
          data: {
            labels,
            datasets
          },
          options
        });
      })
      .catch((error) =&gt; {
        console.error(&#34;Chart failed to load&#34;, error);
      });
    }).catch((error) =&gt; {
      console.warn(&#34;Chart.js or PapaParse not loaded&#34;, error);
    });
  };

  if (document.readyState === &#34;complete&#34;) {
    onReady();
  } else {
    window.addEventListener(&#34;load&#34;, onReady);
  }
})();
&lt;/script&gt;

