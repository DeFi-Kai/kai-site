      })
      .then((csvText) =&gt; {
        const parsed = Papa.parse(csvText, {
          header: true,
          dynamicTyping: true,
          skipEmptyLines: true
        });

        const rows = parsed.data || [];
        const fields = (parsed.meta &amp;&amp; parsed.meta.fields) || [];
        if (!rows.length || !fields.length) {
          console.warn(&#34;No chart data for&#34;, config.src);
          return;
        }

        const xColumn = config.x || fields[0];
        let yColumns = [];
        if (config.y) {
          yColumns = parseList(config.y);
        } else {
          yColumns = fields.filter((field) =&gt; field !== xColumn);
        }

        if (!yColumns.length) {
          console.warn(&#34;No y-axis columns for&#34;, config.src);
          return;
        }

        const labels = rows.map((row) =&gt; row[xColumn]);
        let chartType = config.type || &#34;line&#34;;
        const isArea = chartType === &#34;area&#34;;
        if (isArea) {
          chartType = &#34;line&#34;;
        }
        const isPie = chartType === &#34;pie&#34; || chartType === &#34;doughnut&#34;;

        let datasets = [];
        if (isPie) {
          const yKey = yColumns[0];
          const pieColors = buildColors(labels.length, customColors);
          datasets = [
            {
              label: yKey,
              data: rows.map((row) =&gt; row[yKey]),
              backgroundColor: pieColors,
              borderColor: &#34;rgba(255, 255, 255, 0.6)&#34;,
              borderWidth: 1
            }
          ];
        } else {
          const seriesColors = buildColors(yColumns.length, customColors);
          datasets = yColumns.map((column, index) =&gt; {
            const baseColor = seriesColors[index % seriesColors.length];
            return {
              label: column,
              data: rows.map((row) =&gt; row[column]),
              borderColor: baseColor,
              backgroundColor: withAlpha(baseColor, isArea ? 0.2 : 0.1),
              fill: isArea,
              tension: 0.3,
              borderWidth: 2,
              pointRadius: 2,
              pointHoverRadius: 4
            };
          });
        }

        const style = getComputedStyle(container);
        const gridColor = style.getPropertyValue(&#34;--chart-grid&#34;).trim() || &#34;rgba(0, 0, 0, 0.08)&#34;;
        const textColor = style.getPropertyValue(&#34;--chart-text&#34;).trim() || &#34;rgba(0, 0, 0, 0.75)&#34;;
        const showLegend = isPie || yColumns.length &gt; 1;

        const options = {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: showLegend,
              labels: {
                color: textColor,
                boxWidth: 14
              }
            },
            tooltip: {
              mode: &#34;index&#34;,
              intersect: false
            }
          }
        };

        if (!isPie) {
          const yMin = config.ymin !== &#34;&#34; ? Number(config.ymin) : null;
          const yMax = config.ymax !== &#34;&#34; ? Number(config.ymax) : null;
          options.scales = {
            x: {
              stacked: !!config.stacked,
              grid: {
                color: gridColor
              },
              ticks: {
                color: textColor
              }
            },
            y: {
              stacked: !!config.stacked,
              min: Number.isFinite(yMin) ? yMin : undefined,
              max: Number.isFinite(yMax) ? yMax : undefined,
              grid: {
                color: gridColor
              },
              ticks: {
                color: textColor
              }
            }
          };
        }

        new Chart(canvas, {
          type: chartType,
          data: {
            labels,
            datasets
          },
          options
        });
      })
      .catch((error) =&gt; {
        console.error(&#34;Chart failed to load&#34;, error);
      });
    }).catch((error) =&gt; {
      console.warn(&#34;Chart.js or PapaParse not loaded&#34;, error);
    });
  };

  if (document.readyState === &#34;complete&#34;) {
    onReady();
  } else {
    window.addEventListener(&#34;load&#34;, onReady);
  }
})();
&lt;/script&gt;

